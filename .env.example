# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# Base URL of the deployed app under test (no trailing path needed).
TEST_BASE_URL=https://test.memdecks.com

# Dedicated DISPOSABLE test account. Never use a real user.
# Auth and card-mutating tests sign in with these and clean up after themselves.
TEST_EMAIL=throwaway-test-account@example.com
TEST_PASSWORD=change-me

# Optional. Only needed for the admin API tests in tests/api/server_api_examples.spec.ts.
# Those tests auto-skip when this is empty, so the safe/unauth suites work without it.
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# Live runner service (runner/server.mjs) — only needed when hosting the
# portfolio "Live QA Lab". The test variables above are reused by the runner.
# ---------------------------------------------------------------------------
RUNNER_PORT=8787
# Comma-separated list of allowed browser origins (your portfolio site).
ALLOWED_ORIGINS=http://localhost:5173,https://your-portfolio-domain
# Max runs an individual IP / everyone combined may trigger per rolling hour.
RUNNER_RATE_PER_HOUR=6
RUNNER_GLOBAL_PER_HOUR=40
# Kill a run if it exceeds this many milliseconds.
RUNNER_TIMEOUT_MS=180000
# How many recent HTML reports to keep on disk.
RUNNER_MAX_REPORTS=20
